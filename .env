# hn.fm Environment Configuration

# API Keys
FIRECRAWL_API_KEY=local-dev-key
OPENAI_API_KEY=your_openai_api_key_here

# TTS Service Configuration
TTS_BASE_URL=http://192.168.5.96:7860
TTS_DEFAULT_VOICE=notebooklm

# Studio Voice Configuration (NVIDIA NIM)
STUDIO_VOICE_TARGET=192.168.5.96:8001
STUDIO_VOICE_MODEL_TYPE=48k-hq

# Local LLM Configuration
LLM_BASE_URL=http://192.168.5.173:1234/v1
LLM_FALLBACK_URL=http://192.168.5.96:1234
LLM_MODEL=openai/gpt-oss-20b
LLM_PROVIDER=local

# Firecrawl Configuration
FIRECRAWL_BASE_URL=http://localhost:3002
# For production, use: FIRECRAWL_BASE_URL=https://api.firecrawl.dev


# Firecrawl Configuration
FIRECRAWL_BASE_URL=http://localhost:3002

# Hacker News Configuration
HN_USER_AGENT=hn.fm/0.1.0

# Content Configuration
MAX_EPISODE_LENGTH=15
INCLUDE_COMMENTS=true
QUALITY_THRESHOLD=0.8

# Output Configuration
OUTPUT_FORMATS=podcast,short_video,web
IMAGE_ASPECT_RATIOS=16:9,9:16,1:1

# Development Configuration
DEBUG=true
LOG_LEVEL=INFO
# Local LLM Configuration
LLM_BASE_URL=http://192.168.5.173:1234
LLM_PROVIDER=local
LLM_MODEL=openai/gpt-oss-20b
