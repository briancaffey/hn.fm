# hn.fm Environment Configuration

# API Keys
FIRECRAWL_API_KEY=local-dev-key
OPENAI_API_KEY=your_openai_api_key_here

# TTS Service Configuration
TTS_BASE_URL=http://192.168.5.173:8491
TTS_DEFAULT_VOICE=notebooklm
TTS_TIMEOUT_SECONDS=120
TTS_RETRY_DELAY=5
TTS_MAX_ATTEMPTS=3

# Studio Voice Configuration (NVIDIA NIM)
STUDIO_VOICE_TARGET=192.168.5.173:8001
STUDIO_VOICE_MODEL_TYPE=48k-hq
# Studio Voice HTTP Health Endpoint
STUDIO_VOICE_HTTP_HEALTH_URL=http://192.168.5.173:8000/v1/health/ready

# ASR Service Configuration (WhisperX)
ASR_BASE_URL=http://192.168.5.173:8042
ASR_MODEL_SIZE=large-v2
ASR_TIMEOUT_SECONDS=300
ASR_MAX_ATTEMPTS=3

# Local LLM Configuration
LLM_BASE_URL=http://192.168.5.253:1234/v1
LLM_MODEL=openai/gpt-oss-20b
LLM_PROVIDER=local

# Firecrawl Configuration
FIRECRAWL_BASE_URL=http://192.168.5.226:3002

# Hacker News Configuration
HN_USER_AGENT=hn.fm/0.1.0

# Content Configuration
MAX_EPISODE_LENGTH=15
INCLUDE_COMMENTS=true
QUALITY_THRESHOLD=0.8

# Output Configuration
OUTPUT_FORMATS=podcast,short_video,web
IMAGE_ASPECT_RATIOS=16:9,9:16,1:1

# Development Configuration
DEBUG=true
LOG_LEVEL=INFO


# Image Generation Service Configuration
IMAGE_GENERATION_BASE_URL=http://192.168.5.96:8006

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Image generation
IMAGE_GENERATION_BACKEND=INVOKEAI
INVOKEAI_BASE_URL=http://192.168.5.96:9090