# hn.fm Environment Configuration

# API Keys
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# TTS Service Configuration
TTS_BASE_URL=http://192.168.5.96:7860
TTS_DEFAULT_VOICE=notebooklm
TTS_TIMEOUT_SECONDS=120
TTS_RETRY_DELAY=5
TTS_MAX_ATTEMPTS=3

# Studio Voice Configuration (NVIDIA NIM)
STUDIO_VOICE_TARGET=192.168.5.96:8001
STUDIO_VOICE_MODEL_TYPE=48k-hq
# Studio Voice HTTP Health Endpoint
STUDIO_VOICE_HTTP_HEALTH_URL=http://192.168.5.96:8000/v1/health/ready

# ASR Service Configuration (WhisperX)
ASR_BASE_URL=http://192.168.5.96:8042
ASR_MODEL_SIZE=large-v2
ASR_TIMEOUT_SECONDS=300
ASR_RETRY_DELAY=10
ASR_MAX_ATTEMPTS=5

# Local LLM Configuration
LLM_BASE_URL=http://192.168.5.173:1234/v1
LLM_FALLBACK_URL=http://192.168.5.96:1234
LLM_MODEL=openai/gpt-oss-20b
LLM_PROVIDER=local

# Image Generation Service Configuration
IMAGE_GENERATION_BASE_URL=http://192.168.5.173:8000

# Firecrawl Configuration
FIRECRAWL_BASE_URL=http://localhost:3002
# For production, use: FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# Hacker News Configuration
HN_USER_AGENT=hn.fm/0.1.0 (briancaffey)

# Content Configuration
MAX_EPISODE_LENGTH=15
INCLUDE_COMMENTS=true
QUALITY_THRESHOLD=0.8

# Output Configuration
OUTPUT_FORMATS=podcast,short_video,web
IMAGE_ASPECT_RATIOS=16:9,9:16,1:1

# Development Configuration
DEBUG=false
LOG_LEVEL=INFO

# Web Server Configuration
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_RELOAD=true

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_ALWAYS_EAGER=false
CELERY_WORKER_CONCURRENCY=2
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600
