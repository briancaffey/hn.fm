# hn.fm Environment Configuration

# API Keys
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# TTS Service Configuration
TTS_BASE_URL=http://192.168.5.96:7860
TTS_DEFAULT_VOICE=notebooklm

# Local LLM Configuration
LLM_BASE_URL=http://localhost:8000
LLM_PROVIDER=local
LLM_MODEL=local-model

# Firecrawl Configuration
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
# For local development, use: FIRECRAWL_BASE_URL=http://localhost:3002

# Hacker News Configuration
HN_USER_AGENT=hn.fm/0.1.0 (briancaffey)

# Content Configuration
MAX_EPISODE_LENGTH=15
INCLUDE_COMMENTS=true
QUALITY_THRESHOLD=0.8

# Output Configuration
OUTPUT_FORMATS=podcast,short_video,web
IMAGE_ASPECT_RATIOS=16:9,9:16,1:1

# Development Configuration
DEBUG=true
LOG_LEVEL=INFO
